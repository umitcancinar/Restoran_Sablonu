{
  "rules": {
    "cms": {
      "reservations": {
        ".read": "auth != null",
        "$resId": {
          ".write": "!data.exists() || auth != null"
        }
      },
      "orders": {
        ".read": "auth != null",
        "$orderId": {
          ".write": "!data.exists() || auth != null"
        }
      },
      "settings": {
        ".read": true,
        ".write": "auth != null"
      },
      "navlinks": {
        ".read": true,
        ".write": "auth != null"
      },
      "gallery": {
        ".read": true,
        ".write": "auth != null"
      },
      "menu": {
        ".read": true,
        ".write": "auth != null"
      }
    }
  }
}